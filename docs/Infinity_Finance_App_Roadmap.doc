  h1 { color: #1A237E; text-align: center; border-bottom: 2px solid #1A237E; padding-bottom: 5px; }
  h2 { color: #1A237E; border-bottom: 1px solid #ddd; padding-bottom: 3px; margin-top: 25px;}
  h3 { color: #333; margin-top: 15px; border-left: 4px solid #1A237E; padding-left: 10px; }
  table { width: 100%; border-collapse: collapse; margin-top: 20px; }
