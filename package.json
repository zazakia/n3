{
  "name": "infinityfinance",
  "version": "1.0.24",
  "main": "index.js",
  "scripts": {
    "prepare:app": "npm run generate:updates && node scripts/check-auth-schema.mjs",
    "prestart": "npm run prepare:app",
    "start": "expo start",
    "prestart:local": "npm run prepare:app",
    "start:local": "expo start --clear",
    "start:prod": "node scripts/start-prod.mjs",
    "preandroid": "npm run prepare:app",
    "android": "expo run:android",
    "preios": "npm run prepare:app",
    "ios": "expo run:ios",
    "preweb": "npm run prepare:app",
    "web": "expo start --web",
    "preweb:local": "npm run prepare:app",
    "web:local": "expo start --web --clear",
    "preexport:web": "npm run generate:updates",
    "export:web": "npx expo export --platform web",
    "generate:updates": "node scripts/generate-app-updates.mjs",
    "test": "jest",
    "test:e2e": "npx playwright test",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"app/**/*.{ts,tsx}\"",
    "export:web:production": "node scripts/export-web-production.mjs",
    "postinstall": "patch-package",
    "deploy:cloudflare:infinity": "npm run export:web:production && node scripts/deploy-cloudflare-infinity.mjs",
    "deploy:cloudflare:infinity:upload": "node scripts/deploy-cloudflare-infinity.mjs"
  },
